#!name = 百度搜索去广告
#!desc = 移除百度搜索移动端网页的首页广告信息流
#!icon = https://gitlab.com/lodepuly/iconlibrary/-/raw/main/App_icon/120px/Baidu.png
#!date = 2025-05-13 15:17:08
#!homepage = https://hub.kelee.one
#!author = @Keywos

[MITM]
hostname = m.baidu.com, www.baidu.com

[Script]
http-response ^https?:\/\/(www|m)\.baidu\.com\/?($|\?from=\w{8,9}) script-path=https://kelee.one/Resource/JavaScript/BaiduSearch/BaiduSearchHomePage_remove_ads.js, requires-body=true, timeout=20, tag=移除百度搜索首页信息流广告
