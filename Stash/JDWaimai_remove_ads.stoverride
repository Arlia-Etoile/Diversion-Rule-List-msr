name: |-
  京东外卖去广告
desc: |-
  移除首页推广、点评页面非美食内容、购物车及我的页面推荐、搜索发现、搜索榜单，精简我的页面。
author: |-
  @可莉
icon: |-
  https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/JDWaimai.png
category: |-
  AdBlocker
date: |-
  2025-11-28 02:52:04
homepage: |-
  https://hub.kelee.one

http:

  mitm:
    - "color.jddj.com"
    - "api.m.jd.com"

  url-rewrite:
    - >-
      ^https:\/\/color\.jddj\.com\/client\.action\?functionId=uniformRecommend - reject-dict
    - >-
      ^https:\/\/color\.jddj\.com\/client\.action\?functionId=search_recommendRanking$ - reject-dict

  body-rewrite:
    - >-
      ^https:\/\/color\.jddj\.com\/client\.action\?functionId=hours_home$ response-jq del(.result.config.searchFloor.data[].searchWords) | .result.data |= map(if .tnConfigVO?.businessCode == "nearby_HourlyGo_Operation_Tags" then empty else . end)
    - >-
      ^https:\/\/color\.jddj\.com\/client\.action\?functionId=wmHome$ response-jq (.floors |= map(del(.data.tnData.newsInfo?))) | .floors |= (map(select(.mId != "newWalletIdFloor" and .mId != "recommendfloor"))) | .floors |= (map(.data |= (if .tnData? then del(.tnData.cardList, .tnData.cardListStatic, .tnData.walletList) else . end)))
    - >-
      ^https:\/\/api\.m\.jd\.com\/client\.action$ response-jq delpaths([["data","searchDTO","searchWords"]])
    - >-
      ^https:\/\/api\.m\.jd\.com\/client\.action$ response-jq delpaths([["data","wishlistDTO","bubbleTip"]])
    - >-
      ^https:\/\/api\.m\.jd\.com\/client\.action$ response-jq .data.tabList |= (map(select(.code == "recommendation" or .code == "find_food")) | map(if .code == "recommendation" then .dpHomeFeedTabResultDTOList = .dpHomeFeedTabResultDTOList[0:2] else . end | .dpHomeBannerResultDTOList = []))

